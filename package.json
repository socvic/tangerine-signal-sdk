{
  "name": "tangerine-signal-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for micro-polls Clarity contract interactions on the Stacks blockchain",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:client": "vitest run test/client.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stacks",
    "blockchain",
    "bitcoin",
    "micro-polls",
    "clarity",
    "stx",
    "sdk"
  ],
  "author": "Tangerine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/socvic/tangerine-signal-sdk"
  },
  "dependencies": {
    "@stacks/transactions": "^7.4.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
